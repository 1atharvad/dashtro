# Copy this file to .env and fill in real values. .env is gitignored.

# --- Data backend ---
# "sqlite" (default) or "postgres". mongodb is not yet supported.
DB_TYPE=sqlite

# Only used when DB_TYPE=sqlite (path is inside the backend container).
SQLITE_DB_PATH=db.sqlite3

# Only used when DB_TYPE=postgres. The `postgres` compose service is optional
# (start it with `docker compose --profile postgres up`) — set DB_HOST=postgres
# to use it, or point at your own external Postgres instance instead.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cms
DB_USER=cms
DB_PASSWORD=change-me

# --- Auth ---
JWT_SECRET_KEY=change-me
DEBUG=False

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:7312

# Public-facing base URL used to build absolute media paths in API responses.
# Example (dev, via Cloudflare tunnel): https://local.example.com
# Example (prod): https://cms.example.com
CMS_PUBLIC_URL=

# --- Dev frontend (docker-compose.dev.yml's `frontend` service only) ---
# Hostname the Vite dev server accepts requests for, e.g. your Cloudflare
# tunnel hostname. Unrelated to CMS_PUBLIC_URL (backend-only, prod media URLs).
VITE_DEV_ALLOWED_HOST=local.atharvadevasthali.com
